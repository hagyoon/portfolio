# ── Admin CMS (/admin) ───────────────────────────────────────────────────
# Your login. Generate the hash with: node scripts/hash-password.mjs "pw"
ADMIN_EMAIL=ryuhakyun@gmail.com
ADMIN_PASSWORD_HASH=scrypt:...:...

# Session signing secret — any long random string, e.g. `openssl rand -hex 32`
SESSION_SECRET=

# ── Publishing (production / Vercel) ─────────────────────────────────────
# PAT with contents read/write on BOTH repos below. With this set in
# production, every CMS save commits to the vault (source of truth) and the
# site repo (instant deploy). Without it, the CMS writes to the local
# filesystem (dev mode).
GITHUB_TOKEN=

# Override the repos / mode if needed (defaults shown)
# CONTENT_REPO=hagyoon/obsidian-secondbrain
# SITE_REPO=hagyoon/portfolio
# CMS_MODE=local | github

# ── Account settings & password recovery (production) ───────────────────
# Lets /admin/settings change credentials (they live in Vercel env vars)
# and "Forgot password" send reset links.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
RECOVERY_EMAIL=

# ── Password-reset emails (admin only) ───────────────────────────────────
# From resend.com → API Keys. Used for /admin password recovery, not contact.
RESEND_API_KEY=

# ── Contact form → Telegram (the ONLY contact delivery rail) ─────────────
# Every contact submission is sent to your Telegram bot. Both required.
# Token from @BotFather (the token for your bot):
TELEGRAM_BOT_TOKEN=
# Your personal chat id with that bot. Message the bot once, then visit
# https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}
TELEGRAM_CHAT_ID=
